# ─── Backend (production / Docker) ───────────────────────────────────────────
# Copy to `.env` and adjust. docker-compose reads this file automatically.

# Listening address. 0.0.0.0 inside containers; 127.0.0.1 if a same-host proxy
# fronts the app.
HOST=0.0.0.0
PORT=3001

# Path to the built frontend (vite build output). When set, the backend serves
# it on the same origin — no CORS needed. The Docker image sets this for you.
FRONTEND_DIST=/app/frontend/dist

# CORS allow-list. Comma-separated origins, "*" for any, empty to disable.
# Leave empty when FRONTEND_DIST is set and no separate frontend origin exists.
CORS_ORIGIN=

# SQLite file path. Mount a volume here to persist data across container
# restarts (see docker-compose.yml).
DB_PATH=/app/data/synthetic.db

# Max upload size (MB) for CSV / SQL / Prisma imports.
MAX_UPLOAD_MB=10

# Fastify log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Host port mapping (docker-compose only) ─────────────────────────────────
# Port on the host that maps to the container's PORT. Change if 3001 is taken.
HOST_PORT=3001
